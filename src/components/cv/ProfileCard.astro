---
import type { Profile, ContactInformation } from "@/types/cv.types";
import Card from "@/components/ui/Card.astro";

interface Props {
  profile: Profile;
  contactInfo: ContactInformation | null;
}
const { profile, contactInfo } = Astro.props;
---

<Card>
  <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
    {
      profile.avatar_url && (
        <img
          src={profile.avatar_url}
          alt={profile.name}
          class="h-24 w-24 rounded-full object-cover"
          loading="eager"
        />
      )
    }
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-slate-900">{profile.name}</h1>
      <p class="mt-1 text-lg text-slate-600">{profile.headline}</p>
      {
        profile.location && (
          <p class="mt-1 text-sm text-slate-400">{profile.location}</p>
        )
      }
      {
        profile.bio && (
          <p class="mt-3 text-slate-600">{profile.bio}</p>
        )
      }
      {
        contactInfo && (
          <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1 text-sm text-slate-500">
            {contactInfo.email && <span>{contactInfo.email}</span>}
            {contactInfo.phone && <span>{contactInfo.phone}</span>}
            {contactInfo.linkedin && (
              <a
                href={contactInfo.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-slate-900"
              >
                LinkedIn
              </a>
            )}
            {contactInfo.github && (
              <a
                href={contactInfo.github}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-slate-900"
              >
                GitHub
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</Card>
