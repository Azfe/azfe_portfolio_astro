---
import type { WorkExperience } from "@/types/cv.types";
import { formatDate } from "@/utils/formatters";

interface Props {
  experiences: WorkExperience[];
}

const { experiences } = Astro.props;

const sorted = [...experiences].sort((a, b) => {
  if (!a.end_date && b.end_date) return -1;
  if (a.end_date && !b.end_date) return 1;
  return new Date(b.start_date).getTime() - new Date(a.start_date).getTime();
});
---

<section class="xp-section" id="experiencia">
  <div class="section-wrap">
    <h2 class="section-title">Experiencia</h2>

    {
      sorted.length > 0 ? (
        <div class="timeline">
          {sorted.map((exp) => {
            const isCurrent = !exp.end_date;
            return (
              <div class="timeline-item">
                <div class="timeline-dot" />
                <div class="xp-card">
                  <div class="xp-header">
                    <div class="xp-main">
                      <h3 class="xp-role">{exp.role}</h3>
                      <span class="xp-company">{exp.company}</span>
                    </div>
                    <div class="xp-meta">
                      <span class="xp-dates">
                        {formatDate(exp.start_date)} —{" "}
                        {isCurrent ? <strong>presente</strong> : formatDate(exp.end_date!)}
                      </span>
                    </div>
                  </div>
                  {exp.description && <p class="xp-desc">{exp.description}</p>}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <p class="empty">No hay experiencia disponible.</p>
      )
    }
  </div>
</section>

<style>
  .xp-section {
    padding: 24px 24px 64px;
    background-color: var(--bg);
  }

  .section-wrap {
    max-width: 760px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--line);
    display: flex;
    align-items: center;
    gap: 10px;
    letter-spacing: -0.01em;
  }

  .section-title::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 22px;
    background: var(--blue);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .timeline {
    position: relative;
    padding-left: 28px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--line);
    border-radius: 1px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 24px;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -28px;
    top: 20px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--blue);
    border: 2.5px solid #ffffff;
    box-shadow: 0 0 0 2px rgba(30, 107, 247, 0.25);
  }

  .xp-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px 24px;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--transition);
  }

  .xp-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .xp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
  }

  .xp-role {
    font-size: 17px;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 3px;
    letter-spacing: -0.01em;
  }

  .xp-company {
    font-size: 14px;
    color: var(--ink-2);
    font-weight: 500;
  }

  .xp-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 5px;
    flex-shrink: 0;
  }

  .xp-dates {
    font-size: 13px;
    color: var(--ink-3);
    white-space: nowrap;
  }

  .xp-dates strong {
    color: var(--blue);
    font-weight: 600;
  }

  .xp-desc {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.7;
  }

  .empty {
    color: var(--ink-3);
    font-size: 14px;
  }

  @media (max-width: 600px) {
    .xp-header {
      flex-direction: column;
    }

    .xp-meta {
      align-items: flex-start;
    }
  }
</style>
