---
import Badge from "@/components/ui/Badge.astro";
import type { Skill } from "@/types/cv.types";

interface Props {
  bio: string | null;
  location: string | null;
  skills: Skill[];
  yearsOfExperience: number;
}

const { bio, location, skills, yearsOfExperience } = Astro.props;

type BadgeVariant = "c1" | "c2" | "c3" | "c4" | "c5" | "c6";
const BADGE_VARIANTS: BadgeVariant[] = ["c1", "c2", "c3", "c4", "c5", "c6"];

const uniqueCategories = [...new Set(skills.map((s) => s.category))];
const displaySkills = skills.slice(0, 12).map((s) => ({
  label: s.name,
  cat: BADGE_VARIANTS[uniqueCategories.indexOf(s.category) % BADGE_VARIANTS.length],
}));
---

<section class="about-wrap" id="sobre-mi">
  <div class="about-card">
    <!-- Stats row -->
    <div class="about-stats">
      <div class="stat">
        <span class="stat-value">+{yearsOfExperience}</span>
        <span class="stat-label">años de experiencia</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat stat-route">
        <span class="stat-flag">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="10" r="3"></circle><path
              d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"></path></svg
          >
        </span>
        <span>{location ?? "Barcelona, ES"}</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="available-badge">
          <span class="available-dot"></span>
          Disponible
        </span>
      </div>
    </div>

    <!-- Bio -->
    {bio && <p class="about-bio">{bio}</p>}

    <!-- Skills chips -->
    {
      displaySkills.length > 0 && (
        <div class="skills-chips">
          {displaySkills.map(({ label, cat }) => (
            <Badge label={label} variant={cat} />
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .about-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  .about-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px 36px;
    box-shadow: var(--shadow-card);
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
    padding: 0 16px;
  }

  .stat-route {
    flex-direction: row;
    gap: 6px;
    color: var(--ink-2);
    font-size: 14px;
    font-weight: 500;
    justify-content: center;
  }

  .stat-flag {
    color: var(--ink-3);
    display: flex;
    align-items: center;
  }

  .stat-sep {
    width: 1px;
    height: 36px;
    background: var(--line);
  }

  .stat-value {
    font-size: 28px;
    font-weight: 800;
    color: var(--blue);
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .available-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    background: #e8f8ef;
    color: #0a7a3a;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid #b8eacb;
  }

  .available-dot {
    width: 7px;
    height: 7px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .about-bio {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.75;
    margin-bottom: 24px;
  }

  .about-bio strong {
    color: var(--ink);
    font-weight: 600;
  }

  .skills-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .about-card {
      padding: 24px 20px;
    }

    .about-stats {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .stat-sep {
      width: 100%;
      height: 1px;
    }
  }
</style>
