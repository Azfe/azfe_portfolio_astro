---
import { Image } from "astro:assets";
import profileImg from "/public/profile.png";
import SocialLinks from "@/components/ui/SocialLinks.astro";

interface Props {
  name: string;
  headline: string;
  email: string | null;
  github: string | null;
  linkedin: string | null;
  xUrl: string | null;
  website: string | null;
}

const { name, headline, email, github, linkedin, xUrl, website } = Astro.props;
---

<section class="hero" id="inicio">
  <!-- Avatar -->
  <div class="hero-avatar-wrap">
    <div class="hero-avatar">
      <Image
        src={profileImg}
        alt={name}
        class="hero-avatar-img"
        loading="eager"
        fetchpriority="high"
        width={220}
        height={220}
        format="webp"
        quality={85}
      />
    </div>
  </div>

  <!-- Name & role -->
  <h1 class="hero-title">
    Hola, soy <span class="hero-name">{name}</span>
  </h1>

  <p class="hero-role">
    <span class="hero-dot" aria-hidden="true"></span>
    {headline}
    <span class="hero-dot" aria-hidden="true"></span>
  </p>

  <!-- Social links -->
  <SocialLinks {email} {github} {linkedin} {website} {xUrl} />
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 72px 24px 80px;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-avatar-wrap {
    position: relative;
    margin-bottom: 32px;
  }

  .hero-avatar-wrap::before {
    content: "";
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(30, 107, 247, 0.15), transparent 70%);
    pointer-events: none;
  }

  .hero-avatar {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: linear-gradient(160deg, #0e2a5c, #1e6bf7);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 5px rgba(255, 255, 255, 0.9),
      0 0 40px rgba(30, 107, 247, 0.25);
    position: relative;
    overflow: hidden;
  }

  .hero-avatar::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(34, 74, 143, 0.11), rgba(30, 106, 247, 0.123));
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .hero-name {
    color: var(--accent-color);
  }

  .hero-role {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink-2);
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 20px;
    letter-spacing: 0.01em;
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-color);
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }
</style>
