---
import type { Education, Certification } from "@/types/cv.types";
import { formatDate } from "@/utils/formatters";

interface Props {
  education: Education[];
  certifications: Certification[];
}

const { education, certifications } = Astro.props;

type StudyTag = "grade" | "cert";

interface StudyItem {
  tag: StudyTag;
  tagLabel: string;
  institution: string;
  title: string;
  subtitle: string | null;
  year: string;
  url: string | null;
  description: string | null;
}

const educationItems: StudyItem[] = [...education]
  .sort((a, b) => new Date(b.start_date).getTime() - new Date(a.start_date).getTime())
  .map((e) => ({
    tag: "grade",
    tagLabel: "Formación",
    institution: e.institution,
    title: e.degree,
    subtitle: e.field,
    year: e.end_date
      ? `${new Date(e.start_date).getFullYear()} – ${new Date(e.end_date).getFullYear()}`
      : `${new Date(e.start_date).getFullYear()} – actual`,
    url: null,
    description: e.description,
  }));

const certItems: StudyItem[] = [...certifications]
  .sort((a, b) => new Date(b.issue_date).getTime() - new Date(a.issue_date).getTime())
  .map((c) => ({
    tag: "cert",
    tagLabel: "Certificado",
    institution: c.issuer,
    title: c.title,
    subtitle: null,
    year: formatDate(c.issue_date),
    url: c.credential_url,
    description: null,
  }));

const studies: StudyItem[] = [...educationItems, ...certItems];
---

<section class="studies-section" id="estudios">
  <div class="section-wrap">
    <h2 class="section-title">Estudios</h2>

    {
      studies.length > 0 ? (
        <div class="studies-grid">
          {studies.map((s) => (
            <div class="study-card">
              <span class={`study-tag study-tag--${s.tag}`}>{s.tagLabel}</span>
              <h3 class="study-title">{s.title}</h3>
              <p class="study-provider">{s.institution}</p>
              {s.subtitle && <p class="study-subtitle">{s.subtitle}</p>}
              {s.description && <p class="study-desc">{s.description}</p>}
              <div class="study-footer">
                <span class="study-year">{s.year}</span>
                {s.url && (
                  <a href={s.url} class="study-link" target="_blank" rel="noopener noreferrer">
                    Ver credencial
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="11"
                      height="11"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="empty">No hay estudios disponibles.</p>
      )
    }
  </div>
</section>

<style>
  .studies-section {
    padding: 24px 24px 64px;
  }

  .section-wrap {
    max-width: 760px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--line);
    display: flex;
    align-items: center;
    gap: 10px;
    letter-spacing: -0.01em;
  }

  .section-title::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 22px;
    background: var(--accent-color);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .studies-grid {
    display: grid;
    /* grid-template-columns: 1fr 1fr; */
    gap: 20px;
  }

  .study-card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px 22px 18px;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--transition);
  }

  .study-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .study-tag {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-block;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .study-tag--grade {
    background: #fff1da;
    color: #8f5800;
  }

  .study-tag--cert {
    background: #d8f3e6;
    color: #0a6c39;
  }

  .study-provider {
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
    padding-right: 60px;
  }

  .study-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--accent-color);
    margin-bottom: 5px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .study-subtitle {
    font-size: 13.5px;
    color: var(--ink-2);
    margin-bottom: 8px;
    line-height: 1.5;
  }

  .study-desc {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.55;
    margin-bottom: 16px;
  }

  .study-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    margin-top: auto;
    border-top: 1px dashed var(--line);
  }

  .study-year {
    font-size: 13px;
    color: var(--ink-3);
    font-weight: 500;
  }

  .study-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .study-link:hover {
    opacity: 0.75;
  }

  .empty {
    color: var(--ink-3);
    font-size: 14px;
  }

  @media (max-width: 600px) {
    .studies-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
