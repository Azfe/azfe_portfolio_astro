---
interface Props {
  label: string;
  variant?: "default" | "outline";
  class?: string;
}
const { label, variant = "default", class: className } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center gap-[var(--space-inline-xs)]",
    "rounded-[var(--radius-badge)]",
    "px-[var(--space-inline-sm)] py-[calc(var(--space-inline-xs)-2px)]",
    "font-mono text-xs font-medium tracking-wide",
    variant === "default" &&
      "border border-[var(--badge-border)] bg-[var(--badge-bg)] text-[var(--badge-text)]",
    variant === "outline" &&
      "border border-[var(--border-default)] bg-transparent text-[var(--text-secondary)]",
    className,
  ]}
>
  {label}
</span>
