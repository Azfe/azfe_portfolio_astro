---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div
  class:list={[
    "rounded-[var(--radius-surface)]",
    "border border-[var(--card-border)]",
    "bg-[var(--card-bg)]",
    "p-[var(--space-inline-lg)]",
    "text-[var(--card-text)]",
    "shadow-[var(--card-shadow)]",
    "transition-colors duration-200",
    "hover:bg-[var(--card-bg-hover)]",
    className,
  ]}
>
  <slot />
</div>
