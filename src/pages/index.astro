const experiences: WorkExperience[] = cv?.work_experiences ?? FALLBACK_EXPERIENCES;
const education: Education[] = cv?.education ?? [];
const certifications: Certification[] = cv?.certifications ?? [];
const projects: Project[] = cv?.projects ?? FALLBACK_PROJECTS;

const yearsOfExperience =
  experiences.length > 0
    ? new Date().getFullYear() -
      Math.min(...experiences.map((e) => new Date(e.start_date).getFullYear()))
    : 4;
---

<MainLayout title={PAGE_SEO.home.title} description={PAGE_SEO.home.description}>
  <link rel="preload" as="image" href={optimizedAvatar.src} type="image/webp" slot="head" />
  {
    apiError && (
      <div class="api-notice" role="alert">
        Mostrando datos locales — el servidor no está disponible.
      </div>
    )
  }
  <Hero {name} {headline} {email} {github} {linkedin} {xUrl} {website} />
  <AboutCard {bio} {location} {skills} {yearsOfExperience} />
  <ExperienceSection {experiences} />
  <StudiesSection {education} {certifications} />
  <ProjectsSection {projects} />
  <ContactSection />
</MainLayout>

<style>
  .api-notice {
    background: #fff8e1;
    border-bottom: 1px solid #ffe082;
    color: #795548;
    text-align: center;
    padding: 10px 24px;
    font-size: 13.5px;
  }
</style>
