---
import MainLayout from "@/layouts/MainLayout.astro";
import Hero from "@/components/home/Hero.astro";
import AboutCard from "@/components/home/AboutCard.astro";
import ExperienceSection from "@/components/home/ExperienceSection.astro";
import StudiesSection from "@/components/home/StudiesSection.astro";
import ProjectsSection from "@/components/home/ProjectsSection.astro";
import ContactSection from "@/components/home/ContactSection.astro";
import { PAGE_SEO } from "@/config/seo";
---

<MainLayout title={PAGE_SEO.home.title} description={PAGE_SEO.home.description}>
  <Hero />
  <AboutCard />
  <ExperienceSection />
  <StudiesSection />
  <ProjectsSection />
  <ContactSection />
</MainLayout>
