---
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import { getCVComplete } from "@/services/api/cv.service";
import { ApiError } from "@/services/api/base.service";
import ProfileCard from "@/components/cv/ProfileCard.astro";
import ExperienceList from "@/components/cv/ExperienceList.astro";
import SkillList from "@/components/cv/SkillList.astro";

let cv;
try {
  cv = await getCVComplete();
} catch (err) {
  if (err instanceof ApiError && err.status === 404) {
    return Astro.redirect("/404");
  }
  throw err;
}
---

<MainLayout title="CV">
  <div class="mx-auto max-w-5xl space-y-8 px-6 py-12">
    <ProfileCard profile={cv.profile} contactInfo={cv.contact_info} />
    {cv.work_experiences.length > 0 && (
      <ExperienceList experiences={cv.work_experiences} />
    )}
    {cv.skills.length > 0 && (
      <SkillList skills={cv.skills} />
    )}
  </div>
</MainLayout>
